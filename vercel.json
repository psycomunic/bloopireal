{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/landing/payment-logos/:match*",
      "destination": "/assets/:match*"
    },
    {
      "source": "/assets/:match*",
      "destination": "https://www.bloopi.io/assets/:match*"
    }
  ],
  "headers": [
    {
      "source": "/assets/logo-bluen-blue-CCittD31.svg",
      "headers": [
        { "key": "Content-Type", "value": "image/png" }
      ]
    },
    {
      "source": "/assets/logo-bluen-white-Bf3UH5JC.svg",
      "headers": [
        { "key": "Content-Type", "value": "image/png" }
      ]
    }
  ]
}
